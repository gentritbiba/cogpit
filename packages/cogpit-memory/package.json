{
  "name": "cogpit-memory",
  "version": "0.1.10",
  "description": "CLI tool for Claude Code and Codex session introspection",
  "packageManager": "bun@1.3.14",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cogpit-memory": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "skill/"
  ],
  "scripts": {
    "test": "bun test",
    "test:contracts": "bun run build:npm && node scripts/test-package-contract.mjs",
    "build": "bun build --compile src/cli.ts --outfile cogpit-memory",
    "build:npm": "node scripts/build-npm.mjs && tsc --pretty false -p tsconfig.build.json",
    "prepublishOnly": "bun run build:npm"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "bun-types": "latest",
    "esbuild": "^0.27.3",
    "typescript": "~5.6.2"
  }
}
