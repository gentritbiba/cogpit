{
  "name": "cogpit",
  "private": true,
  "version": "1.1.2",
  "description": "Control center for Claude Code and OpenAI Codex agent sessions",
  "license": "MIT",
  "author": {
    "name": "Gentrit Biba",
    "email": "gentritbiba@gmail.com"
  },
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "vite --host",
    "build": "bun run typecheck && bun run build:web",
    "build:web": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "check:architecture": "bun scripts/check-architecture.ts",
    "check:audit": "bun scripts/check-audit.ts",
    "check:cogpit-memory-sync": "bun scripts/sync-cogpit-memory.ts --check",
    "check:duplicates": "bun scripts/check-duplicates.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "bun run typecheck:app && bun run typecheck:server && bun run typecheck:electron && bun run typecheck:memory",
    "typecheck:app": "tsc --noEmit --pretty false -p tsconfig.app.prod.json",
    "typecheck:server": "tsc --noEmit --pretty false -p tsconfig.node.prod.json",
    "typecheck:electron": "tsc --noEmit --pretty false -p tsconfig.electron.json",
    "typecheck:memory": "tsc --noEmit --pretty false -p packages/cogpit-memory/tsconfig.prod.json",
    "typecheck:tests": "bun run typecheck:tests:app && bun run typecheck:tests:server && bun run typecheck:tests:memory",
    "typecheck:tests:app": "tsc --noEmit --pretty false -p tsconfig.app.json",
    "typecheck:tests:server": "tsc --noEmit --pretty false -p tsconfig.node.json",
    "typecheck:tests:memory": "tsc --noEmit --pretty false -p packages/cogpit-memory/tsconfig.json",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build",
    "electron:preview": "electron-vite build && electron .",
    "electron:package": "start=$(date +%s) && electron-vite build && electron-builder --publish never && echo \"\\n✅ electron:package completed in $(($(date +%s) - start))s\"",
    "postinstall": "electron-builder install-app-deps",
    "serve": "bun run build && bun server/standalone.ts",
    "serve:start": "bun server/standalone.ts",
    "sync-cogpit-memory": "bun scripts/sync-cogpit-memory.ts",
    "ui:add": "shadcn add"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.215",
    "@anthropic-ai/sdk": "^0.112.4",
    "@base-ui/react": "^1.2.0",
    "@shikijs/langs": "^3.22.0",
    "@shikijs/themes": "^3.22.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "react-resizable-panels": "^4.7.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.22.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^40.10.6",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^28.1.0",
    "jscpd": "^5.0.12",
    "shadcn": "^4.13.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "@xmldom/xmldom": "0.8.13",
    "body-parser": "2.3.0",
    "fast-uri": "3.1.4",
    "flatted": "3.4.2",
    "form-data": "4.0.6",
    "hono": "4.12.31",
    "js-yaml": "4.3.0",
    "lodash": "4.18.1",
    "postcss": "8.5.20",
    "qs": "6.15.3",
    "tar": "7.5.20",
    "tmp": "0.2.7",
    "undici": "7.28.0"
  }
}
